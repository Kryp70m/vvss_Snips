# Volume Sniper production defaults
UNIVERSE_MAX_SYMBOLS=700
CUSTOM_UNIVERSE_MAX_SYMBOLS=700
MAX_SYMBOLS_PER_EXCHANGE=700
ENABLED_SPOT_EXCHANGES=binance,mexc
ENABLED_PERP_EXCHANGES=binance,mexc
STREAM_CHUNK_SIZE=50
SCAN_INTERVAL_MS=1000
OI_POLL_SECONDS=0
INCLUDE_KLINE_STREAM=true
INCLUDE_INDIVIDUAL_TRADE_STREAM=false
INCLUDE_BOOK_TICKER_STREAM=false
BOOTSTRAP_NATR_KLINES=true
